# Komun environment variables
# Copy this to .env and fill in your values
# The .env file is gitignored and will never be committed

# Database
DB_USER=komun
DB_PASSWORD=generate-a-strong-password-here
DB_NAME=komun

# JWT secret (generate with: openssl rand -base64 48)
JWT_SECRET=generate-a-random-string-and-paste-it-here

# Relay — enable in config.toml with:
# [relay]
# enabled = true
# external_url = "wss://relay.yourdomain.com"
